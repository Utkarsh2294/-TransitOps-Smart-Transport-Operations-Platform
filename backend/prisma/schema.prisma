generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  fleet_manager
  driver
  safety_officer
  financial_analyst
}

enum VehicleStatus {
  Available
  On_Trip
  In_Shop
  Retired
}

enum DriverStatus {
  Available
  On_Trip
  Off_Duty
  Suspended
}

enum TripStatus {
  Draft
  Dispatched
  Completed
  Cancelled
}

enum MaintenanceStatus {
  Open
  Closed
}

enum ExpenseCategory {
  toll
  fine
  other
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime @default(now())
  trips        Trip[]
}

model Vehicle {
  id                Int              @id @default(autoincrement())
  regNumber         String           @unique
  name              String
  type              String
  maxLoadCapacityKg Decimal          @db.Decimal(12, 2)
  odometerKm        Decimal          @default(0) @db.Decimal(12, 2)
  acquisitionCost   Decimal          @db.Decimal(12, 2)
  status            VehicleStatus    @default(Available)
  createdAt         DateTime         @default(now())
  trips             Trip[]
  maintenanceLogs   MaintenanceLog[]
  fuelLogs          FuelLog[]
  expenses          Expense[]

  @@index([status])
  @@index([type])
}

model Driver {
  id                Int          @id @default(autoincrement())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Int          @default(100)
  status            DriverStatus @default(Available)
  createdAt         DateTime     @default(now())
  trips             Trip[]

  @@index([status])
  @@index([licenseExpiryDate])
}

model Trip {
  id                  Int       @id @default(autoincrement())
  source              String
  destination         String
  vehicleId           Int
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id])
  driverId            Int
  driver              Driver    @relation(fields: [driverId], references: [id])
  cargoWeightKg       Decimal   @db.Decimal(12, 2)
  plannedDistanceKm   Decimal   @db.Decimal(12, 2)
  finalOdometerKm     Decimal?  @db.Decimal(12, 2)
  fuelConsumedLiters  Decimal?  @db.Decimal(12, 2)
  status              TripStatus @default(Draft)
  createdById         Int
  createdBy           User      @relation(fields: [createdById], references: [id])
  createdAt           DateTime  @default(now())
  fuelLogs            FuelLog[]

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id        Int               @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle           @relation(fields: [vehicleId], references: [id])
  type      String
  cost      Decimal           @db.Decimal(12, 2)
  status    MaintenanceStatus @default(Open)
  openedAt  DateTime          @default(now())
  closedAt  DateTime?

  @@index([vehicleId, status])
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  tripId    Int?
  trip      Trip?    @relation(fields: [tripId], references: [id])
  liters    Decimal  @db.Decimal(12, 2)
  cost      Decimal  @db.Decimal(12, 2)
  date      DateTime @default(now())

  @@index([vehicleId, date])
}

model Expense {
  id        Int             @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle         @relation(fields: [vehicleId], references: [id])
  category  ExpenseCategory
  amount    Decimal         @db.Decimal(12, 2)
  date      DateTime        @default(now())
  note      String?
}

